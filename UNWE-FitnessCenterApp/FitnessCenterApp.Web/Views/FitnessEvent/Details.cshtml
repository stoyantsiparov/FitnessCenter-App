@model FitnessCenterApp.Web.ViewModels.FitnessEvent.FitnessEventDetailsViewModel

<div class="container mt-5 mb-5">
	<h2 class="text-center">@Model.Title</h2>
	<hr class="mb-4" />

	<div class="card shadow-sm mx-auto" style="max-width: 900px; border-color: #8697C4;">
		<div class="row g-0">
			<div class="col-md-5 d-flex align-items-center justify-content-center p-3">
				@if (!string.IsNullOrEmpty(Model.ImageUrl))
				{
					<img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Title" style="max-height: 400px; object-fit: cover;" />
				}
				else
				{
					<img src="~/img/no-image-available-02.jpg" class="img-fluid rounded" alt="No Image Available" style="max-height: 400px; object-fit: cover;" />
				}
			</div>

			<div class="col-md-7">
				<div class="card-body d-flex flex-column h-100 p-4">
					<h4 class="card-title text-primary mb-3">Event Information</h4>
                    
					<p class="card-text"><strong><i class="bi bi-geo-alt"></i> Location:</strong> @Model.Location</p>
					<p class="card-text flex-grow-1"><strong>Description:</strong> @Model.Description</p>
                    
					<div class="alert py-2 mb-4" style="background-color: #EDE8F5; border-color: #ADBBDA;">
						<p class="mb-1"><strong>Start:</strong> @Model.StartDateTime</p>
						<p class="mb-1"><strong>End:</strong> @Model.EndDateTime</p>
						<p class="mb-0"><strong>Capacity:</strong> @Model.Capacity spots total</p>
					</div>

					<div class="mt-auto d-flex gap-2">
						<form method="post" asp-action="AddToMyFitnessEvents" asp-route-id="@Model.Id" class="w-50">
							<button type="submit" class="btn btn-primary w-100">Register</button>
						</form>
						<a asp-controller="FitnessEvent" asp-action="Index" class="btn btn-outline-secondary w-50">Back to List</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}