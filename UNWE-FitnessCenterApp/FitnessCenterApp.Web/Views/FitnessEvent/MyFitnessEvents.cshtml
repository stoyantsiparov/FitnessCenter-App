@model IEnumerable<FitnessCenterApp.Web.ViewModels.FitnessEvent.AllFitnessEventsViewModel>

@{
	ViewData["Title"] = "My Fitness Events";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-5" />

@if (!Model.Any())
{
	<div class="text-center">
		<h4 class="text-muted">You haven't registered for any events yet.</h4>
		<a asp-controller="FitnessEvent" asp-action="Index" class="btn btn-primary mt-3">Browse Events</a>
	</div>
}
else
{
	<div class="row row-cols-1 row-cols-md-3 g-4">
		@foreach (var fitnessEvent in Model)
		{
			<div class="col">
				<div class="card h-100" style="border-color: #8697C4;">
					@if (!string.IsNullOrEmpty(fitnessEvent.ImageUrl))
					{
						<img class="card-img-top" src="@fitnessEvent.ImageUrl" alt="@fitnessEvent.Title" style="height: 200px; object-fit: cover;">
					}
					else
					{
						<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 200px; object-fit: cover;">
						}

						<div class="card-body d-flex flex-column">
							<h5 class="card-title text-center text-primary">@fitnessEvent.Title</h5>
							<hr class="mt-2 mb-3" />

							<p class="card-text flex-grow-1 text-center">
								<strong><i class="bi bi-geo-alt"></i> Location:</strong><br /> @fitnessEvent.Location
							</p>
                        
							<div class="alert text-center py-2 mb-3" style="background-color: #EDE8F5; border-color: #ADBBDA; font-size: 0.9rem;">
								<strong>Start:</strong> @fitnessEvent.StartDateTime<br />
								<strong>End:</strong> @fitnessEvent.EndDateTime
							</div>

							<div class="mt-auto">
								<form method="post" asp-action="RemoveFromMyFitnessEvents" asp-route-id="@fitnessEvent.Id">
									<button type="submit" class="btn btn-danger w-100">Cancel Registration</button>
								</form>
							</div>
						</div>
					</div>
				</div>
			}
		</div>
	}

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}