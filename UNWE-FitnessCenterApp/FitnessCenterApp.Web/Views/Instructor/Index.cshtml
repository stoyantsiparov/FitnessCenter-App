@model IEnumerable<FitnessCenterApp.Web.ViewModels.Instructor.AllInstructorsViewModel>

@{
	ViewData["Title"] = "Our Instructors";
}

<div class="text-center mt-5 mb-4">
	<h2>@ViewData["Title"]</h2>
	<p class="text-muted">Meet the professionals who will guide you on your fitness journey.</p>
</div>
<hr class="mb-4" />

<form method="get" asp-controller="Instructor" asp-action="Index" class="mb-5 bg-white p-4 rounded shadow-sm" style="border: 1px solid #8697C4;">
	<div class="row g-3">
		<div class="col-md-9">
			<input type="text" name="searchQuery" class="form-control" placeholder="Search instructor by name or specialization..." />
		</div>
		<div class="col-md-3 d-flex gap-2">
			<button type="submit" class="btn btn-primary w-100">Search</button>
			<a asp-controller="Instructor" asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
		</div>
	</div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
	@foreach (var instructor in Model)
	{
		<div class="col">
			<div class="card h-100 text-center shadow-sm" style="border-color: #8697C4; border-width: 1px;">
				<div class="pt-4 pb-3" style="background-color: #EDE8F5;">
					@if (!string.IsNullOrEmpty(instructor.ImageUrl))
					{
						<img class="rounded-circle shadow-sm" src="@instructor.ImageUrl" alt="@instructor.FirstName @instructor.LastName" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid white;">
					}
					else
					{
						<img class="rounded-circle shadow-sm" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid white;">
						}
					</div>

					<div class="card-body d-flex flex-column">
						<h4 class="card-title text-primary fw-bold mt-2">@instructor.FirstName @instructor.LastName</h4>
						<h6 class="text-muted mb-4"><i class="bi bi-star-fill text-warning"></i> @instructor.Specialization</h6>

						<div class="mt-auto">
							<a asp-controller="Instructor" asp-action="Details" asp-route-id="@instructor.Id" class="btn btn-outline-primary w-100">View Profile</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}