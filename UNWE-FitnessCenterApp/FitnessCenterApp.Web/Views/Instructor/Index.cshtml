@model IEnumerable<FitnessCenterApp.Web.ViewModels.Instructor.AllInstructorsViewModel>

@{
	ViewData["Title"] = "Our Instructors";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-5" />

<div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
	@foreach (var instructor in Model)
	{
		<div class="col">
			<div class="card h-100 shadow-sm text-center" style="border-color: #8697C4; border-radius: 15px; overflow: hidden;">
                
				@if (!string.IsNullOrEmpty(instructor.ImageUrl))
				{
					<img class="card-img-top" src="@instructor.ImageUrl" alt="@instructor.FirstName" style="height: 300px; object-fit: cover; object-position: top;">
				}
				else
				{
					<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 300px; object-fit: cover;">
					}

					<div class="card-body d-flex flex-column">
						<h4 class="card-title text-primary fw-bold mb-1">@instructor.FirstName @instructor.LastName</h4>
                    
						<p class="text-muted flex-grow-1 mb-3">
							<i class="bi bi-star-fill text-warning me-1"></i> @instructor.Specialization
						</p>

						<div class="mt-auto">
							<a asp-controller="Instructor" asp-action="Details" asp-route-id="@instructor.Id" class="btn btn-outline-primary w-100 py-2">View Details</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}