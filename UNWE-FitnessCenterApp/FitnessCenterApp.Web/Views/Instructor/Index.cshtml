@model FitnessCenterApp.Web.ViewModels.Instructor.PaginatedInstructorsViewModel

@{
	ViewData["Title"] = "Our Instructors";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-5" />

<form method="get" asp-controller="Instructor" asp-action="Index" class="mb-5 bg-white p-4 rounded shadow-sm" style="border: 1px solid #8697C4;">
	<div class="row g-3">
		<div class="col-md-9">
			<input type="text" name="searchQuery" class="form-control" value="@Model.SearchQuery" placeholder="Search by name or specialization..." />
		</div>
		<div class="col-md-3 d-flex gap-2">
			<button type="submit" class="btn btn-primary w-100">Search</button>
			<a asp-controller="Instructor" asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
		</div>
	</div>
</form>

@if (!Model.Instructors.Any())
{
	<div class="text-center mt-5">
		<i class="bi bi-person-x text-muted" style="font-size: 4rem;"></i>
		<h4 class="text-muted mt-3">No instructors found matching your criteria.</h4>
	</div>
}
else
{
	<div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center mb-4">
		@foreach (var instructor in Model.Instructors)
		{
			<div class="col">
				<div class="card h-100 shadow-sm text-center" style="border-color: #8697C4; border-radius: 15px; overflow: hidden;">
					
					@if (!string.IsNullOrEmpty(instructor.ImageUrl))
					{
						<img class="card-img-top" src="@instructor.ImageUrl" alt="@instructor.FirstName" style="height: 300px; object-fit: cover; object-position: top;">
					}
					else
					{
						<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 300px; object-fit: cover;">
						}

						<div class="card-body d-flex flex-column">
							<h4 class="card-title text-primary fw-bold mb-1">@instructor.FirstName @instructor.LastName</h4>
						
							<p class="text-muted flex-grow-1 mb-3">
								<i class="bi bi-star-fill text-warning me-1"></i> @instructor.Specialization
							</p>

							<div class="mt-auto">
								<a asp-controller="Instructor" asp-action="Details" asp-route-id="@instructor.Id" class="btn btn-outline-primary w-100 py-2">View Details</a>
							</div>
						</div>
					</div>
				</div>
			}
		</div>

		@if (Model.TotalPages > 1)
		{
			<nav aria-label="Page navigation" class="mt-5">
				<ul class="pagination justify-content-center">
					@if (Model.PageNumber > 1)
					{
						<li class="page-item">
							<a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-searchQuery="@Model.SearchQuery">Previous</a>
						</li>
					}

					@for (int i = 1; i <= Model.TotalPages; i++)
					{
						<li class="page-item @(i == Model.PageNumber ? "active" : "")">
							<a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchQuery="@Model.SearchQuery">@i</a>
						</li>
					}

					@if (Model.PageNumber < Model.TotalPages)
					{
						<li class="page-item">
							<a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-searchQuery="@Model.SearchQuery">Next</a>
						</li>
					}
				</ul>
			</nav>
		}
	}

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}