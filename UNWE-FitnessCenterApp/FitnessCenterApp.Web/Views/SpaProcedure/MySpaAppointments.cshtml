@model IEnumerable<FitnessCenterApp.Web.ViewModels.SpaProcedure.AllSpaProceduresViewModel>

@{
	ViewData["Title"] = "My Spa Appointments";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-5" />

@if (!Model.Any())
{
	<div class="text-center">
		<h4 class="text-muted">You haven't booked any spa procedures yet.</h4>
		<a asp-controller="SpaProcedure" asp-action="Index" class="btn btn-primary mt-3">Browse Procedures</a>
	</div>
}
else
{
	<div class="row row-cols-1 row-cols-md-3 g-4">
		@foreach (var appointment in Model)
		{
			<div class="col">
				<div class="card h-100" style="border-color: #8697C4;">
					@if (!string.IsNullOrEmpty(appointment.ImageUrl))
					{
						<img class="card-img-top" src="@appointment.ImageUrl" alt="@appointment.Name" style="height: 200px; object-fit: cover;">
					}
					else
					{
						<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 200px; object-fit: cover;">
						}

						<div class="card-body d-flex flex-column">
							<h5 class="card-title text-center text-primary">@appointment.Name</h5>
							<hr class="mt-2 mb-3" />

							<p class="card-text flex-grow-1 text-center">@appointment.Description</p>
                        
							<div class="alert text-center py-2 mb-3" style="background-color: #EDE8F5; border-color: #ADBBDA; font-size: 0.9rem;">
								<i class="bi bi-calendar-check"></i> Appointment Date & Time:<br />
								<strong>@appointment.AppointmentDateTime</strong>
							</div>

							<div class="mt-auto">
								<form method="post" asp-controller="SpaProcedure" asp-action="RemoveFromMySpaAppointment" asp-route-id="@appointment.Id">
									<button type="submit" class="btn btn-danger w-100">Cancel Appointment</button>
								</form>
							</div>
						</div>
					</div>
				</div>
			}
		</div>
	}

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}