@model FitnessCenterApp.Web.ViewModels.SpaProcedure.SpaProcedureDetailsViewModel

<div class="container mt-5 mb-5">
	<h2 class="text-center">@Model.Name</h2>
	<hr class="mb-4" />

	<div class="card shadow-sm mx-auto" style="max-width: 900px; border-color: #8697C4;">
		<div class="row g-0">
			<div class="col-md-5 d-flex align-items-center justify-content-center p-3">
				@if (!string.IsNullOrEmpty(Model.ImageUrl))
				{
					<img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" style="max-height: 400px; object-fit: cover;" />
				}
				else
				{
					<img src="~/img/no-image-available-02.jpg" class="img-fluid rounded" alt="No Image Available" style="max-height: 400px; object-fit: cover;" />
				}
			</div>

			<div class="col-md-7">
				<div class="card-body d-flex flex-column h-100 p-4">
					<h4 class="card-title text-primary mb-3">Procedure Information</h4>
                    
					<p class="card-text flex-grow-1"><strong>Description:</strong><br /> @Model.Description</p>
                    
					<div class="alert py-2 mb-4" style="background-color: #EDE8F5; border-color: #ADBBDA;">
						<p class="mb-1"><strong><i class="bi bi-tag"></i> Price:</strong> @Model.Price.ToString("C")</p>
						<p class="mb-1"><strong><i class="bi bi-clock"></i> Duration:</strong> @Model.Duration minutes</p>
						<p class="mb-0"><strong><i class="bi bi-people"></i> Capacity:</strong> @Model.Capacity spots total</p>
					</div>

					<div class="mt-auto">
						<form method="post" asp-action="AddToMySpaAppointments" asp-route-id="@Model.Id" class="bg-light p-3 rounded mb-3" style="border: 1px solid #ADBBDA;">
							<div class="form-group mb-3">
								<label for="appointmentDateTime" class="form-label fw-bold">Select Appointment Date and Time:</label>
								<input type="datetime-local" name="appointmentDateTime" id="appointmentDateTime" class="form-control border-primary" required />
							</div>
                            
							<button type="submit" class="btn btn-primary w-100 fw-bold">Book Now</button>
						</form>
						<a asp-controller="SpaProcedure" asp-action="Index" class="btn btn-outline-secondary w-100">Back to List</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />

	<script>
		// Get current date and time
		var today = new Date();

		// Remove timezone offset to format correctly in local time
		today.setMinutes(today.getMinutes() - today.getTimezoneOffset());

		// Set the min attribute for the input to today's date
		var minDate = today.toISOString().slice(0, 16);
		document.getElementById("appointmentDateTime").setAttribute("min", minDate);

		// Get the date 7 days from today
		var maxDateObj = new Date();
		maxDateObj.setDate(maxDateObj.getDate() + 7);
		maxDateObj.setMinutes(maxDateObj.getMinutes() - maxDateObj.getTimezoneOffset());

		var maxDate = maxDateObj.toISOString().slice(0, 16);
		document.getElementById("appointmentDateTime").setAttribute("max", maxDate);

		document.getElementById("appointmentDateTime").closest("form").addEventListener("submit", function (e) {
			if (document.getElementById("appointmentDateTime").value) {
				var selectedDate = new Date(document.getElementById("appointmentDateTime").value);
				var hours = selectedDate.getHours();
				var minutes = selectedDate.getMinutes();
				if (hours < 9 || hours > 18 || (hours === 18 && minutes > 0)) {
					e.preventDefault();
					alert("Appointments can only be booked between 09:00 and 18:00. Please select a valid time.");
				}
			}
		});
	</script>
}