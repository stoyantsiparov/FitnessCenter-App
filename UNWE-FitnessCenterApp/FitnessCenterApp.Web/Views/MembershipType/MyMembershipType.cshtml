@model IEnumerable<FitnessCenterApp.Web.ViewModels.MembershipType.AllMembershipTypeViewModel>

@{
	ViewData["Title"] = "My Active Membership";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-5" />

@if (Model != null && Model.Any())
{
	<div class="row g-4 justify-content-center">
		@foreach (var membership in Model)
		{
			<div class="col-auto">
				<div class="card h-100 shadow-sm" style="width: 22rem; border-color: #8697C4; border-width: 1px; border-radius: 15px; overflow: hidden;">
                    
					<div class="text-center pt-4 pb-2 bg-white">
						<h4 class="card-title text-primary fw-bold mb-0">@membership.Name</h4>
					</div>

					@if (!string.IsNullOrEmpty(membership.ImageUrl))
					{
						<img src="@membership.ImageUrl" alt="@membership.Name" style="height: 220px; width: 100%; object-fit: cover;">
					}
					else
					{
						<img src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 220px; width: 100%; object-fit: cover;">
						}

						<div class="card-body d-flex flex-column text-center">
							<div class="alert py-3 mb-4 mt-2" style="background-color: #EDE8F5; border-color: #ADBBDA; border-radius: 10px;">
								<p class="mb-0 text-dark fs-5">Duration: @membership.Duration days</p>
							</div>

							<div class="mt-auto d-flex flex-column gap-2">
								<form method="post" asp-action="RemoveMyMembership" asp-route-id="@membership.Id" onsubmit="return confirm('Are you sure you want to cancel your membership? You will lose access immediately.');">
									<button type="submit" class="btn btn-danger w-100 py-2 fw-bold">CANCEL MEMBERSHIP</button>
								</form>
								<a asp-controller="MembershipType" asp-action="Details" asp-route-id="@membership.Id" class="btn btn-outline-primary w-100 py-2">VIEW DETAILS</a>
							</div>
						</div>
					</div>
				</div>
			}
		</div>
	}
else
	{
		<div class="text-center mt-5">
			<i class="bi bi-card-checklist text-muted" style="font-size: 4rem;"></i>
			<h4 class="text-muted mt-3">You currently have no active membership.</h4>
			<a asp-action="Index" class="btn btn-primary mt-3 px-5 py-2 fw-bold">BROWSE PLANS</a>
		</div>
	}

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}