@model IEnumerable<FitnessCenterApp.Web.ViewModels.MembershipType.AllMembershipTypeViewModel>

@{
	ViewData["Title"] = "Available Membership Plans";
}

<div class="text-center mt-5 mb-5">
	<h2>@ViewData["Title"]</h2>
	<p class="text-muted">Choose the perfect plan for your fitness journey.</p>
</div>
<hr class="mb-5" />

<div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
	@foreach (var membershipType in Model)
	{
		<div class="col">
			<div class="card h-100 text-center shadow-sm" style="border-color: #8697C4; border-width: 2px;">
				@if (!string.IsNullOrEmpty(membershipType.ImageUrl))
				{
					<img class="card-img-top" src="@membershipType.ImageUrl" alt="@membershipType.Name" style="height: 200px; object-fit: cover;">
				}
				else
				{
					<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 200px; object-fit: cover;">
					}

					<div class="card-body d-flex flex-column">
						<h4 class="card-title text-primary fw-bold mt-2">@membershipType.Name</h4>
						<h5 class="text-dark mb-3">@membershipType.Price.ToString("C")</h5>
                    
						<ul class="list-unstyled mb-4 flex-grow-1">
							<li class="mb-2"><i class="bi bi-calendar-check text-success"></i> Duration: @membershipType.Duration days</li>
							<li class="mb-2"><i class="bi bi-check-circle text-success"></i> Full Club Access</li>
							<li class="mb-2"><i class="bi bi-check-circle text-success"></i> Book Classes & Spa</li>
						</ul>

						<div class="mt-auto d-flex flex-column gap-2">
							<form method="post" asp-controller="MembershipType" asp-action="AddMyMembership" asp-route-id="@membershipType.Id">
								<button type="submit" class="btn btn-primary w-100 btn-lg">Buy Membership</button>
							</form>
							<a asp-controller="MembershipType" asp-action="Details" asp-route-id="@membershipType.Id" class="btn btn-outline-primary w-100">View Details</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}