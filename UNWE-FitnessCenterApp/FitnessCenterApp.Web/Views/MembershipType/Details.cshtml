@model FitnessCenterApp.Web.ViewModels.MembershipType.MembershipTypeDetailsViewModel

<div class="container mt-5 mb-5">
	<h2 class="text-center">@Model.Name Plan</h2>
	<hr class="mb-4" />

	<div class="card shadow-sm mx-auto" style="max-width: 800px; border-color: #8697C4;">
		<div class="row g-0">
			<div class="col-md-5 d-flex align-items-center justify-content-center p-3">
				@if (!string.IsNullOrEmpty(Model.ImageUrl))
				{
					<img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" style="max-height: 400px; object-fit: cover;" />
				}
				else
				{
					<img src="~/img/no-image-available-02.jpg" class="img-fluid rounded" alt="No Image Available" style="max-height: 400px; object-fit: cover;" />
				}
			</div>

			<div class="col-md-7">
				<div class="card-body d-flex flex-column h-100 p-4">
					<h3 class="card-title text-primary mb-3">@Model.Name</h3>
					<h4 class="text-dark mb-3">@Model.Price.ToString("C")</h4>
                    
					<p class="card-text flex-grow-1"><strong>Description:</strong><br /> @Model.Description</p>
                    
					<div class="alert py-2 mb-4 text-center" style="background-color: #EDE8F5; border-color: #ADBBDA;">
						<strong><i class="bi bi-clock-history"></i> Valid for:</strong> @Model.Duration days
					</div>

					<div class="mt-auto d-flex gap-2">
						<form method="post" asp-action="AddMyMembership" asp-route-id="@Model.Id" class="w-50">
							<button type="submit" class="btn btn-primary w-100 text-uppercase fw-bold">Buy Now</button>
						</form>
						<a asp-controller="MembershipType" asp-action="Index" class="btn btn-outline-secondary w-50">Back to Plans</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}