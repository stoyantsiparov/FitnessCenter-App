@{
	ViewData["Title"] = "Page Not Found";
}

<div class="container text-center mt-5 mb-5 py-5">
	<h1 class="display-1 text-primary" style="font-weight: bold;">404</h1>
	<h2 class="text-dark">Oops! The page you're looking for doesn't exist.</h2>
	<p class="text-muted mb-4">It seems you may have taken a wrong turn. Don't worry, it happens to the best of us.</p>
	<a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">Return to Home</a>
</div>