@model FitnessCenterApp.Web.ViewModels.FitnessClass.FitnessClassDetailsViewModel

<div class="container mt-5 mb-5">
    <h2 class="text-center">@Model.Name</h2>
    <hr class="mb-4" />

    <div class="card shadow-sm mx-auto" style="max-width: 900px; border-color: #8697C4;">
        <div class="row g-0">
            <div class="col-md-5 d-flex align-items-center justify-content-center p-3">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" style="max-height: 400px; object-fit: cover;" />
                }
                else
                {
                    <img src="~/img/no-image-available-02.jpg" class="img-fluid rounded" alt="No Image Available" style="max-height: 400px; object-fit: cover;" />
                }
            </div>

            <div class="col-md-7">
                <div class="card-body d-flex flex-column h-100 p-4">
                    <h4 class="card-title text-primary mb-3">Class Information</h4>
                    
                    <p class="card-text flex-grow-1"><strong>Description:</strong><br /> @Model.Description</p>
                    
                    <div class="alert py-2 mb-4" style="background-color: #EDE8F5; border-color: #ADBBDA;">
                        <p class="mb-1"><strong><i class="bi bi-tag"></i> Price:</strong> @Model.Price.ToString("C")</p>
                        <p class="mb-1"><strong><i class="bi bi-calendar-event"></i> Schedule:</strong> @Model.Schedule</p>
                        <p class="mb-1"><strong><i class="bi bi-clock"></i> Duration:</strong> @Model.Duration minutes</p>
                        <p class="mb-0"><strong><i class="bi bi-people"></i> Capacity:</strong> @Model.Capacity spots total</p>
                    </div>

                    <div class="mt-auto d-flex gap-2">
                        <form method="post" asp-action="AddToMyClasses" asp-route-id="@Model.Id" class="w-50">
                            <button type="submit" class="btn btn-primary w-100">Register</button>
                        </form>
                        <a asp-controller="FitnessClass" asp-action="Index" class="btn btn-outline-secondary w-50">Back to List</a>
                    </div>

                    <button class="btn btn-outline-primary mt-3 w-100" id="showInstructorBtn">Show Instructor Details</button>
                </div>
            </div>
        </div>
    </div>

    <div id="instructorInfo" class="mt-4 mx-auto" style="display: none; max-width: 900px;">
        <div class="card" style="background-color: #EDE8F5; border-color: #8697C4;">
            <div class="card-body">
                <h5 class="text-center mb-3">Instructor Details</h5>
                <div class="row">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.Instructor.ImageUrl))
                        {
                            <img src="@Model.Instructor.ImageUrl" class="img-fluid rounded-circle shadow-sm" alt="Instructor Image" style="width: 150px; height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <img src="~/img/no-image-available-02.jpg" class="img-fluid rounded-circle shadow-sm" alt="No Instructor Image" style="width: 150px; height: 150px; object-fit: cover;" />
                        }
                    </div>
                    <div class="col-md-8 d-flex flex-column justify-content-center">
                        <p class="mb-1"><strong>Name:</strong> @Model.Instructor.FirstName @Model.Instructor.LastName</p>
                        <p class="mb-1"><strong>Specialty:</strong> @Model.Instructor.Specialization</p>
                        <p class="mb-0"><strong>Bio:</strong> @Model.Instructor.Bio</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('showInstructorBtn').addEventListener('click', function () {
            var instructorInfo = document.getElementById('instructorInfo');
            var button = document.getElementById('showInstructorBtn');

            if (instructorInfo.style.display === 'none') {
                instructorInfo.style.display = 'block';
                button.innerText = 'Hide Instructor Details';
            } else {
                instructorInfo.style.display = 'none';
                button.innerText = 'Show Instructor Details';
            }
        });
    </script>
}