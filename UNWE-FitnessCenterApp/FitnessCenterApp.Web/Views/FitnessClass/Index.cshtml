@model FitnessCenterApp.Web.ViewModels.FitnessClass.PaginatedFitnessClassesViewModel

@{
	ViewData["Title"] = "Available Fitness Classes";
}

<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<hr class="mb-4" />

<form method="get" asp-controller="FitnessClass" asp-action="Index" class="mb-5 bg-white p-4 rounded shadow-sm" style="border: 1px solid #8697C4;">
	<div class="row g-3">
		<div class="col-md-6">
			<input type="text" name="searchQuery" class="form-control" value="@Model.SearchQuery" placeholder="Search classes by name..." />
		</div>
		<div class="col-md-2">
			<input type="number" name="minDuration" class="form-control" value="@Model.MinDuration" placeholder="Min Duration" />
		</div>
		<div class="col-md-2">
			<input type="number" name="maxDuration" class="form-control" value="@Model.MaxDuration" placeholder="Max Duration" />
		</div>
		<div class="col-md-2 d-flex gap-2">
			<button type="submit" class="btn btn-primary w-100">Search</button>
			<a asp-controller="FitnessClass" asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
		</div>
	</div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-4">
	@foreach (var fitnessClass in Model.FitnessClasses)
	{
		<div class="col">
			<div class="card h-100" style="border-color: #8697C4;">
				@if (!string.IsNullOrEmpty(fitnessClass.ImageUrl))
				{
					<img class="card-img-top" src="@fitnessClass.ImageUrl" alt="@fitnessClass.Name" style="height: 200px; object-fit: cover;">
				}
				else
				{
					<img class="card-img-top" src="~/img/no-image-available-02.jpg" alt="No Image Available" style="height: 200px; object-fit: cover;">
					}

					<div class="card-body d-flex flex-column">
						<h5 class="card-title text-center text-primary">@fitnessClass.Name</h5>
						<hr class="mt-2 mb-3" />

						<p class="card-text flex-grow-1 text-center">
							<strong><i class="bi bi-calendar-event"></i> Schedule:</strong><br /> @fitnessClass.Schedule
						</p>
                    
						<div class="alert text-center py-2 mb-3" style="background-color: #EDE8F5; border-color: #ADBBDA; font-size: 0.9rem;">
							<strong><i class="bi bi-clock"></i> Duration:</strong> @fitnessClass.Duration min<br />
							<strong><i class="bi bi-people"></i> Spots:</strong> @fitnessClass.Capacity
						</div>

						<div class="mt-auto d-flex flex-column gap-2">
							<form method="post" asp-controller="FitnessClass" asp-action="AddToMyClasses" asp-route-id="@fitnessClass.Id">
								<button type="submit" class="btn btn-primary w-100">Register</button>
							</form>
							<a asp-controller="FitnessClass" asp-action="Details" asp-route-id="@fitnessClass.Id" class="btn btn-outline-primary w-100">View Details</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>

	@if (Model.TotalPages > 1)
	{
		<nav aria-label="Page navigation" class="mt-5">
			<ul class="pagination justify-content-center">
				@if (Model.HasPreviousPage)
				{
					<li class="page-item">
						<a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-minDuration="@Model.MinDuration" asp-route-maxDuration="@Model.MaxDuration">Previous</a>
					</li>
				}

				@for (int i = 1; i <= Model.TotalPages; i++)
				{
					<li class="page-item @(i == Model.PageNumber ? "active" : "")">
						<a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-searchQuery="@Model.SearchQuery" asp-route-minDuration="@Model.MinDuration" asp-route-maxDuration="@Model.MaxDuration">@i</a>
					</li>
				}

				@if (Model.HasNextPage)
				{
					<li class="page-item">
						<a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-searchQuery="@Model.SearchQuery" asp-route-minDuration="@Model.MinDuration" asp-route-maxDuration="@Model.MaxDuration">Next</a>
					</li>
				}
			</ul>
		</nav>
	}

	@section Scripts {
		<partial name="_ValidationScriptsPartial" />
	}